---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AroundWorldSection from '../components/sections/AroundWorldSection.astro';
import DreamSection from '../components/sections/DreamSection.astro';
import JourneySection from '../components/sections/JourneySection.astro';
import MemoriesSection from '../components/sections/MemoriesSection.astro';
import ExperiencesSection from '../components/sections/ExperiencesSection.astro';
import DestinationsSection from '../components/sections/DestinationsSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import CTASection from '../components/sections/CTASection.astro';

const pageMeta = {
  title: 'Wander & Wonder | Colecciona historias que contarás para siempre',
  description: 'Diseñamos viajes a medida para aquellos que buscan conectar, explorar y coleccionar momentos inolvidables alrededor del mundo.',
  ogImage: '/og-image.jpg',
};
---

<PageLayout meta={pageMeta}>
  <div class="overflow-x-hidden">
    <!-- Scene 1: The Call -->
    <HeroSection />

    <!-- Scene 2: Around the World -->
    <AroundWorldSection />

    <!-- Scene 3: Dream Before Departure -->
    <DreamSection />

    <!-- Scene 4: The Journey -->
    <JourneySection />

    <!-- Scene 5: Memories -->
    <MemoriesSection />

    <!-- Scene 6: Experiences -->
    <ExperiencesSection />

    <!-- Scene 7: Destinations -->
    <DestinationsSection />

    <!-- Scene 8: Why Wander & Wonder -->
    <AboutSection />

    <!-- Scene 9: Your Next Story -->
    <CTASection />
  </div>
</PageLayout>
