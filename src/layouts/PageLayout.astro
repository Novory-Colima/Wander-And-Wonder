---
import RootLayout from './RootLayout.astro';
import Navbar from '@components/navigation/Navbar.astro';
import Footer from '@components/sections/FooterSection.astro';
import NovoryTopBar from '../novory/NovoryTopBar.astro';
import NovoryFloatingBadge from '../novory/NovoryFloatingBadge.astro';
import NovoryFinalCTA from '../novory/NovoryFinalCTA.astro';
import type { PageMeta } from '@/types';

interface Props {
  meta?: Partial<PageMeta>;
}

const { meta } = Astro.props;
---

<RootLayout meta={meta}>
  <!-- Skip Link for Accessibility -->
  <a href="#main-content" class="skip-link">
    Saltar al contenido principal
  </a>

  <!-- Novory TopBar (sobre el navbar) -->
  <NovoryTopBar />

  <!-- Navigation -->
  <Navbar />

  <!-- Main Content -->
  <main id="main-content" role="main" tabindex="-1" class="focus:outline-none">
    <slot />
  </main>

  <!-- Footer -->
  <Footer />

  <!-- Novory Final CTA (después del footer) -->
  <NovoryFinalCTA />

  <!-- Novory Floating Badge (componente flotante) -->
  <NovoryFloatingBadge />
</RootLayout>
