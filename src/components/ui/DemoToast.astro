---
---

<div
  id="demo-toast"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] flex items-center gap-3 px-6 py-4 rounded-full bg-midnight/90 backdrop-blur-md border border-ivory/10 shadow-[0_10px_40px_rgba(0,0,0,0.5)] transform translate-y-[150%] opacity-0 transition-all duration-500 ease-[var(--ease-smooth)] pointer-events-none"
  role="alert"
  aria-live="polite"
>
  <div class="w-2 h-2 rounded-full bg-sunset shadow-[0_0_8px_rgba(255,165,0,0.6)]"></div>
  <p class="font-sans text-xs md:text-sm text-ivory tracking-wide m-0">
    Esta es una versión de demostración del portafolio.
  </p>
</div>

<style>
  #demo-toast.show {
    transform: translate(-50%, 0);
    opacity: 1;
  }
</style>

<script>
  declare global {
    interface Window {
      showDemoToast: () => void;
      demoToastTimeout: number;
    }
  }

  // Global function to show demo toast
  window.showDemoToast = function() {
    const toast = document.getElementById('demo-toast');
    if (!toast) return;

    toast.classList.remove('show');
    // Force reflow
    void toast.offsetWidth;
    toast.classList.add('show');

    // Clear existing timeout if any
    if (window.demoToastTimeout) {
      clearTimeout(window.demoToastTimeout);
    }

    window.demoToastTimeout = window.setTimeout(() => {
      toast.classList.remove('show');
    }, 3500);
  };

  document.addEventListener('astro:page-load', () => {
    // Add click listeners to any element with data-demo-action
    const demoElements = document.querySelectorAll('[data-demo-action]');
    demoElements.forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        window.showDemoToast();
      });
    });
  });
</script>
