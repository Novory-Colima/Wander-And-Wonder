<div class="scroll-indicator flex flex-col items-center gap-3" aria-hidden="true">
  <span class="font-sans text-[10px] text-ivory/40 uppercase tracking-[0.3em]">
    Scroll
  </span>
  <div class="scroll-line relative w-px h-10 bg-ivory/10 overflow-hidden rounded-full">
    <div class="scroll-dot absolute top-0 left-0 w-full h-3 bg-sunset/60 rounded-full"></div>
  </div>
</div>

<style>
  .scroll-dot {
    animation: scrollPulse 2s var(--ease-smooth) infinite;
  }

  @keyframes scrollPulse {
    0% {
      transform: translateY(-100%);
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    100% {
      transform: translateY(300%);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-dot {
      animation: none;
      transform: translateY(0);
      opacity: 0.6;
    }
  }
</style>
