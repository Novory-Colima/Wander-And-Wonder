---
import { LANGUAGES, DEFAULT_LANGUAGE } from '@/config/site';
---

<div class="relative group">
  <button
    type="button"
    class="flex items-center gap-2 text-ivory/80 hover:text-ivory transition-colors font-sans text-xs uppercase tracking-widest"
    aria-label="Cambiar idioma"
    data-demo-action="lang"
  >
    <span>{DEFAULT_LANGUAGE.toUpperCase()}</span>
    <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>
</div>
