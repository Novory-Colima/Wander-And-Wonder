---

<button
  type="button"
  id="mobile-menu-toggle"
  class="relative z-50 flex flex-col items-center justify-center w-10 h-10 gap-1.5"
  aria-label="Abrir menú de navegación"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <span class="menu-line w-6 h-[1.5px] bg-ivory transition-all duration-300 origin-center"></span>
  <span class="menu-line w-6 h-[1.5px] bg-ivory transition-all duration-300 origin-center"></span>
  <span class="menu-line w-4 h-[1.5px] bg-ivory transition-all duration-300 origin-center ml-auto"></span>
</button>

<script>
  function initMobileMenu(): void {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    let isOpen = false;

    function openMenu(): void {
      isOpen = true;
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Cerrar menú de navegación');
      toggle?.classList.add('is-active');
      menu?.classList.add('is-open');
      menu?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Set focus to the first link inside the menu after a small delay
      setTimeout(() => {
        const firstLink = menu?.querySelector('a, button') as HTMLElement;
        if (firstLink) firstLink.focus();
      }, 100);
    }

    function closeMenu(): void {
      isOpen = false;
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Abrir menú de navegación');
      toggle?.classList.remove('is-active');
      menu?.classList.remove('is-open');
      menu?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Return focus to the toggle button
      toggle?.focus();
    }

    toggle.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    // Close on nav link click
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>

<style>
  .is-active .menu-line:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }

  .is-active .menu-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .is-active .menu-line:nth-child(3) {
    width: 1.5rem;
    transform: translateY(-5.5px) rotate(-45deg);
  }
</style>
