---
interface Props {
  label: string;
  href: string;
  variant?: 'desktop' | 'mobile';
}

const { label, href, variant = 'desktop' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'nav-item relative inline-block font-sans font-medium transition-all',
    'focus:outline-none focus-visible:outline-2 focus-visible:outline-sunset focus-visible:outline-offset-4 rounded-sm',
    variant === 'mobile'
      ? 'text-2xl py-2'
      : 'text-sm px-3 py-2 tracking-wide uppercase',
  ]}
  style="color: #F8F6F2; text-shadow: 0 2px 4px rgba(0,0,0,0.4);"
>
  <span class="relative z-10">{label}</span>
  <span class="nav-item-line" aria-hidden="true"></span>
</a>

<style>
  .nav-item {
    /* Removed overflow: hidden to allow focus outline rendering */
  }

  .nav-item-line {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-sunset);
    transform: translateX(-50%);
    transition: width var(--duration-300) var(--ease-smooth);
  }

  .nav-item:hover .nav-item-line,
  .nav-item:focus-visible .nav-item-line {
    width: 60%;
  }
</style>
