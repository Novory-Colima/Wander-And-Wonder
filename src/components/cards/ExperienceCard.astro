---
import type { Experience } from '@/types';

interface Props {
  experience: Experience;
  class?: string;
}

const { experience, class: className = '' } = Astro.props;
---

<article class="group relative overflow-hidden rounded-sm cursor-pointer aspect-[4/5] w-full">
  <img
    src={experience.image}
    alt={experience.alt}
    loading="lazy"
    class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-midnight/10 via-transparent to-midnight-dark/90 opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>

  <div class="absolute inset-x-0 bottom-0 p-6 md:p-8 flex flex-col justify-end">
    <h3 class="font-serif text-3xl md:text-4xl text-ivory font-medium mb-3 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-[var(--ease-smooth)]">
      {experience.title}
    </h3>
    <p class="font-sans text-sm md:text-base text-cloud-light leading-relaxed opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-100 ease-[var(--ease-smooth)]">
      {experience.description}
    </p>
  </div>
</article>
