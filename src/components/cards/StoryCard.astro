---
import type { Story } from '@/types';
import EditorialImage from '../blocks/EditorialImage.astro';

interface Props {
  story: Story;
  class?: string;
  dark?: boolean;
}

const { story, class: className = '', dark = true } = Astro.props;
---

<article
  class:list={[
    'story-card flex flex-col group',
    className,
  ]}
>
  <div class="relative overflow-hidden rounded-2xl mb-6 aspect-[4/5] max-h-[60vh]">
    <img
      src={story.image}
      alt={story.alt}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-[2s] ease-out group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-midnight-dark/80 via-midnight/20 to-transparent pointer-events-none"></div>
    
    <div class="absolute bottom-6 left-6 right-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-1.5 h-1.5 rounded-full bg-sunset"></span>
        <span class="font-sans text-xs font-semibold uppercase tracking-[0.2em] text-ivory/90">
          {story.location}
        </span>
      </div>
    </div>
  </div>

  <blockquote class="px-2">
    <p class:list={['font-serif text-2xl md:text-3xl leading-snug italic mb-4 text-balance', dark ? 'text-ivory' : 'text-midnight']}>
      "{story.quote}"
    </p>
    <footer class="flex items-center gap-3">
      <div class:list={['w-8 h-px', dark ? 'bg-sunset/40' : 'bg-sunset']}></div>
      <div class="flex flex-col">
        <span class:list={['font-sans text-sm font-medium', dark ? 'text-ivory/80' : 'text-midnight/80']}>
          {story.author}
        </span>
        <span class:list={['font-sans text-xs', dark ? 'text-cloud-light' : 'text-cloud-dark']}>
          {story.date}
        </span>
      </div>
    </footer>
  </blockquote>
</article>
