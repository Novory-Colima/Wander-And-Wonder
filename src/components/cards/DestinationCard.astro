---
import type { Destination } from '@/types';
import CTAButton from '../ui/CTAButton.astro';

interface Props {
  destination: Destination;
  class?: string;
}

const { destination, class: className = '' } = Astro.props;
---

<article class="group relative flex flex-col gap-6 cursor-pointer">
  {/* Image Container */}
  <div class="relative w-full overflow-hidden rounded-sm aspect-[4/5]">
    <img
      src={destination.image}
      alt={destination.alt}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-midnight/10 group-hover:bg-transparent transition-colors duration-500"></div>
  </div>

  <div class="flex-1 flex flex-col px-2">
    <h3 class="font-serif text-2xl md:text-3xl text-midnight font-medium mb-3">
      {destination.country}
    </h3>
    <p class="font-sans text-sm md:text-base text-cloud-dark leading-relaxed mb-6 flex-1">
      {destination.description}
    </p>

    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3">
        <svg class="w-4 h-4 text-sunset" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="font-sans text-sm text-cloud-dark">{destination.duration}</span>
      </div>
      <div class="flex items-center gap-3">
        <svg class="w-4 h-4 text-sunset" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
        </svg>
        <span class="font-sans text-sm text-cloud-dark">{destination.season}</span>
      </div>
    </div>

    <div class="mt-auto">
      <CTAButton text="Descubrir" href={`#destinations`} size="sm" variant="primary" />
    </div>
  </div>
</article>
