---
import Caption from '@components/common/Caption.astro';

interface Props {
  src: string;
  alt: string;
  caption?: string;
  aspectRatio?: 'auto' | 'square' | 'video' | 'portrait' | 'landscape';
  class?: string;
  dark?: boolean;
}

const {
  src,
  alt,
  caption,
  aspectRatio = 'auto',
  class: className = '',
  dark = false,
} = Astro.props;

const aspectClasses = {
  auto: '',
  square: 'aspect-square object-cover',
  video: 'aspect-video object-cover',
  portrait: 'aspect-[3/4] object-cover',
  landscape: 'aspect-[4/3] object-cover',
};
---

<figure class:list={['group relative', className]}>
  <div class="editorial-image-wrapper overflow-hidden bg-cloud/10 w-full h-full">
    <img
      src={src}
      alt={alt}
      class:list={[
        'w-[110%] h-[110%] max-w-none transition-transform duration-[2s] ease-out group-hover:scale-110',
        aspectClasses[aspectRatio],
      ]}
    />
  </div>
  {caption && (
    <Caption dark={dark} class="mt-4">
      {caption}
    </Caption>
  )}
</figure>
