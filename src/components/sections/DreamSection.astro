---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';
import EditorialImage from '@components/blocks/EditorialImage.astro';

import dreamMainImg from '@/assets/images/dream-airplane-window.webp';
import dreamPassportImg from '@/assets/images/dream-passport-map.webp';
import dreamCameraImg from '@/assets/images/dream-camera-journal.png';
import dreamSuitcaseImg from '@/assets/images/dream-small-suitcase.png';

// High quality editorial images for Scene 3
const mainImage = dreamMainImg.src; // Airport/Airplane window
const smallImages = [
  { src: dreamPassportImg.src, alt: 'Pasaporte sobre mapa' },
  { src: dreamCameraImg.src, alt: 'Cámara analógica y diario' },
  { src: dreamSuitcaseImg.src, alt: 'Maleta de cuero pequeña' }
];
---

<SectionContainer id="dream" padding="none" class="bg-ivory-warm pt-32 pb-32">
  <Container class="max-w-7xl mx-auto px-4 md:px-8">
    <!-- Huge Editorial Image -->
    <div class="mb-32 md:mb-48 w-full">
      <EditorialImage 
        src={mainImage} 
        alt="Mirando por la ventana del avión hacia las nubes" 
        aspectRatio="video"
        class="w-full rounded-sm"
      />
    </div>

    <!-- Phrase -->
    <div class="max-w-4xl mx-auto text-center mb-24 md:mb-32 px-4">
      <DisplayTitle as="h2" class="text-midnight leading-[1.1]">
        El viaje comienza mucho antes <br class="hidden md:block"/> de subir al avión.
      </DisplayTitle>
      <p class="mt-8 font-sans text-lg md:text-xl text-cloud-dark max-w-2xl mx-auto leading-relaxed">
        Comienza en esa primera conversación. En el momento en que decides que es hora de irte. En la emoción de empacar lo indispensable y dejar espacio para lo inesperado.
      </p>
    </div>

    <!-- Small moments (Editorial blocks, not cards) -->
    <div class="dream-moments-container grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-8 max-w-6xl mx-auto mt-24 md:mt-40 relative z-10">
      
      <!-- Preparar -->
      <div class="dream-moment col-span-1 md:col-span-4 md:col-start-1" data-speed="0.9">
        <EditorialImage 
          src={smallImages[0].src} 
          alt={smallImages[0].alt} 
          aspectRatio="portrait" 
          class="mb-8 rounded-none w-full shadow-2xl shadow-midnight/10"
        />
        <div class="px-2">
          <span class="font-sans text-xs font-medium uppercase tracking-widest text-sunset/80 block mb-3">Preparar</span>
          <p class="font-serif text-2xl italic text-midnight/90 leading-snug">El mapa sobre la mesa marcando lugares que aún no puedes pronunciar.</p>
        </div>
      </div>

      <!-- Imaginar -->
      <div class="dream-moment col-span-1 md:col-span-5 md:col-start-7 md:mt-32" data-speed="1.15">
        <EditorialImage 
          src={smallImages[1].src} 
          alt={smallImages[1].alt} 
          aspectRatio="square" 
          class="mb-8 rounded-none w-full shadow-2xl shadow-midnight/10"
        />
        <div class="px-2">
          <span class="font-sans text-xs font-medium uppercase tracking-widest text-sunset/80 block mb-3">Imaginar</span>
          <p class="font-serif text-2xl italic text-midnight/90 leading-snug">La lista de canciones perfecta para mirar por la ventana del tren.</p>
        </div>
      </div>

      <!-- Empacar -->
      <div class="dream-moment col-span-1 md:col-span-6 md:col-start-3 md:-mt-16 relative z-20" data-speed="0.8">
        <EditorialImage 
          src={smallImages[2].src} 
          alt={smallImages[2].alt} 
          aspectRatio="video" 
          class="mb-8 rounded-none w-full shadow-2xl shadow-midnight/10"
        />
        <div class="px-2">
          <span class="font-sans text-xs font-medium uppercase tracking-widest text-sunset/80 block mb-3">Empacar</span>
          <p class="font-serif text-2xl italic text-midnight/90 leading-snug">Llevar solo lo necesario para moverte con libertad.</p>
        </div>
      </div>

    </div>
  </Container>
</SectionContainer>

<script>
  import { initDreamAnimation } from '@/animations/dream';

  document.addEventListener('astro:page-load', () => {
    initDreamAnimation();
  });
</script>
