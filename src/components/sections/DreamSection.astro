---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';

import dreamMainImg from '@/assets/images/dream-airplane-window.webp';
import dreamPassportImg from '@/assets/images/dream-passport-map.webp';
import dreamCameraImg from '@/assets/images/dream-camera-journal.png';
import dreamSuitcaseImg from '@/assets/images/dream-small-suitcase.png';
---

<SectionContainer id="dream" padding="none" class="bg-midnight relative overflow-hidden py-20 px-4 max-w-7xl mx-auto">
  <!-- Pinned Container -->
  <div id="dream-pin-container" class="h-screen w-full relative flex items-center justify-center">
    
    <!-- Central Text Layer (z-10, constrained max-width) -->
    <div id="dream-text-center" class="relative z-10 max-w-2xl mx-auto text-center pointer-events-none">
      <DisplayTitle as="h2" class="text-ivory leading-tight text-3xl sm:text-5xl md:text-6xl break-words">
        El viaje comienza mucho antes <br class="hidden md:block"/> de subir al avión.
      </DisplayTitle>
      <p class="mt-6 font-sans text-sm sm:text-base md:text-lg text-ivory/70 leading-relaxed">
        Comienza en esa primera conversación. En el momento en que decides que es hora de irte. En la emoción de empacar lo indispensable y dejar espacio para lo inesperado.
      </p>
    </div>

    <!-- Polaroid Cards Layer (z-0, absolute in corners, normalized dimensions) -->
    <div id="dream-collage" class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
      
      <!-- Card 0: Preparar (Top Left) -->
      <div class="collage-item absolute left-4 top-10 w-44 md:w-52 opacity-0 pointer-events-auto cursor-none group" data-index="0">
        <div class="relative shadow-xl bg-white p-3 pb-6 border border-slate-200/50" style="transform: rotate(-6deg);">
          <div class="overflow-hidden aspect-[3/4] w-full relative bg-slate-100">
            <img src={dreamPassportImg.src} alt="Pasaporte sobre mapa" loading="lazy" class="absolute inset-0 w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700" />
          </div>
          <div class="mt-3 flex justify-between items-center px-1">
            <span class="font-sans text-[0.65rem] tracking-widest uppercase text-slate-800 font-bold">Preparar</span>
            <div class="w-1.5 h-1.5 rounded-full bg-sunset"></div>
          </div>
        </div>
      </div>

      <!-- Card 1: Imaginar (Top Right) -->
      <div class="collage-item absolute right-4 top-6 w-44 md:w-52 opacity-0 pointer-events-auto cursor-none group" data-index="1">
        <div class="relative shadow-xl bg-white p-3 pb-6 border border-slate-200/50" style="transform: rotate(3deg);">
          <div class="overflow-hidden aspect-[3/4] w-full relative bg-slate-100">
            <img src={dreamCameraImg.src} alt="Cámara analógica y diario" loading="lazy" class="absolute inset-0 w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700" />
          </div>
          <div class="mt-3 flex justify-between items-center px-1">
            <span class="font-sans text-[0.65rem] tracking-widest uppercase text-slate-800 font-bold">Imaginar</span>
            <div class="w-1.5 h-1.5 rounded-full bg-sunset"></div>
          </div>
        </div>
      </div>

      <!-- Card 2: Empacar (Bottom Left) -->
      <div class="collage-item absolute left-12 bottom-4 w-44 md:w-52 opacity-0 pointer-events-auto cursor-none group" data-index="2">
        <div class="relative shadow-xl bg-white p-3 pb-6 border border-slate-200/50" style="transform: rotate(-3deg);">
          <div class="overflow-hidden aspect-[3/4] w-full relative bg-slate-100">
            <img src={dreamSuitcaseImg.src} alt="Maleta de cuero pequeña" loading="lazy" class="absolute inset-0 w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700" />
          </div>
          <div class="mt-3 flex justify-between items-center px-1">
            <span class="font-sans text-[0.65rem] tracking-widest uppercase text-slate-800 font-bold">Empacar</span>
            <div class="w-1.5 h-1.5 rounded-full bg-sunset"></div>
          </div>
        </div>
      </div>

      <!-- Card 3: Partir (Bottom Right) -->
      <div class="collage-item absolute right-12 bottom-10 w-44 md:w-52 opacity-0 pointer-events-auto cursor-none group" data-index="3">
        <div class="relative shadow-xl bg-white p-3 pb-6 border border-slate-200/50" style="transform: rotate(6deg);">
          <div class="overflow-hidden aspect-[3/4] w-full relative bg-slate-100">
            <img src={dreamMainImg.src} alt="Mirando por la ventana del avión" loading="lazy" class="absolute inset-0 w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700" />
          </div>
          <div class="mt-3 flex justify-between items-center px-1">
            <span class="font-sans text-[0.65rem] tracking-widest uppercase text-slate-800 font-bold">Partir</span>
            <div class="w-1.5 h-1.5 rounded-full bg-sunset"></div>
          </div>
        </div>
      </div>

    </div>

  </div>
</SectionContainer>

<script>
  import { initDreamAnimation } from '@/animations/dream';

  document.addEventListener('astro:page-load', () => {
    initDreamAnimation();
  });
</script>
