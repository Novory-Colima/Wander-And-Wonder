---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';
import EditorialImage from '@components/blocks/EditorialImage.astro';

// High quality editorial images for Scene 3
const mainImage = 'https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=1474&auto=format&fit=crop'; // Airport/Airplane window
const smallImages = [
  { src: 'https://images.unsplash.com/photo-1553531384-cc64ac80f931?q=80&w=1664&auto=format&fit=crop', alt: 'Pasaporte sobre mapa' },
  { src: 'https://images.unsplash.com/photo-1516007204481-b5f7ee281315?q=80&w=1470&auto=format&fit=crop', alt: 'Cámara analógica y diario' },
  { src: 'https://images.unsplash.com/photo-1512413914565-1d428fa6935c?q=80&w=1470&auto=format&fit=crop', alt: 'Maleta de cuero pequeña' }
];
---

<SectionContainer id="dream" padding="none" class="bg-ivory-warm pt-32 pb-32">
  <Container class="max-w-7xl mx-auto px-4 md:px-8">
    <!-- Huge Editorial Image -->
    <div class="mb-32 md:mb-48 w-full">
      <EditorialImage 
        src={mainImage} 
        alt="Mirando por la ventana del avión hacia las nubes" 
        aspectRatio="video"
        class="w-full rounded-sm"
      />
    </div>

    <!-- Phrase -->
    <div class="max-w-4xl mx-auto text-center mb-24 md:mb-32 px-4">
      <DisplayTitle as="h2" class="text-midnight leading-[1.1]">
        El viaje comienza mucho antes <br class="hidden md:block"/> de subir al avión.
      </DisplayTitle>
      <p class="mt-8 font-sans text-lg md:text-xl text-cloud-dark max-w-2xl mx-auto leading-relaxed">
        Comienza en esa primera conversación. En el momento en que decides que es hora de irte. En la emoción de empacar lo indispensable y dejar espacio para lo inesperado.
      </p>
    </div>

    <!-- Small moments (Editorial blocks, not cards) -->
    <div class="dream-moments-container flex flex-col md:flex-row flex-wrap justify-between items-start max-w-6xl mx-auto mt-24 md:mt-32 gap-y-16 md:gap-y-0 relative z-10">
      
      <!-- Preparar -->
      <div class="dream-moment w-full md:w-[32%] flex flex-col md:mt-0" data-speed="0.9">
        <EditorialImage 
          src={smallImages[0].src} 
          alt={smallImages[0].alt} 
          aspectRatio="portrait" 
          class="mb-6 rounded-sm w-full max-w-[280px] mx-auto md:max-w-full shadow-lg"
        />
        <div class="px-4 text-center md:text-left">
          <span class="font-sans text-xs font-semibold uppercase tracking-widest text-sunset block mb-2">Preparar</span>
          <p class="font-serif text-xl italic text-midnight/80">El mapa sobre la mesa marcando lugares que aún no puedes pronunciar.</p>
        </div>
      </div>

      <!-- Imaginar -->
      <div class="dream-moment w-full md:w-[42%] flex flex-col md:mt-[15%] md:ml-auto" data-speed="1.15">
        <EditorialImage 
          src={smallImages[1].src} 
          alt={smallImages[1].alt} 
          aspectRatio="square" 
          class="mb-6 rounded-sm w-full max-w-[320px] mx-auto md:max-w-full shadow-lg"
        />
        <div class="px-4 text-center md:text-left">
          <span class="font-sans text-xs font-semibold uppercase tracking-widest text-sunset block mb-2">Imaginar</span>
          <p class="font-serif text-xl italic text-midnight/80">La lista de canciones perfecta para mirar por la ventana del tren.</p>
        </div>
      </div>

      <!-- Empacar -->
      <div class="dream-moment w-full md:w-[35%] flex flex-col md:-mt-[5%] md:ml-[5%] relative z-20" data-speed="0.8">
        <EditorialImage 
          src={smallImages[2].src} 
          alt={smallImages[2].alt} 
          aspectRatio="video" 
          class="mb-6 rounded-sm w-full max-w-[280px] mx-auto md:max-w-full shadow-lg"
        />
        <div class="px-4 text-center md:text-left">
          <span class="font-sans text-xs font-semibold uppercase tracking-widest text-sunset block mb-2">Empacar</span>
          <p class="font-serif text-xl italic text-midnight/80">Llevar solo lo necesario para moverte con libertad.</p>
        </div>
      </div>

    </div>
  </Container>
</SectionContainer>

<script>
  import { initDreamAnimation } from '@/animations/dream';

  document.addEventListener('astro:page-load', () => {
    initDreamAnimation();
  });
</script>
