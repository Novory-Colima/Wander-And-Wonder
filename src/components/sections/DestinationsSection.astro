---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';
import { destinations } from '@/content/es/destinations';

// Tomamos solo 4 destinos para mantener el impacto editorial alto y no saturar
const featuredDestinations = destinations.slice(0, 4);
---

<SectionContainer id="destinations" padding="none" class="bg-ivory relative pt-32 pb-48 md:pt-48 md:pb-64">
  <!-- Capa de transición de color desde la escena anterior (midnight) -->
  <div class="dest-bg-transition absolute inset-0 bg-[#070F18] z-0 pointer-events-none transform-gpu"></div>

  <Container class="relative z-10 max-w-7xl mx-auto px-4 md:px-8">
    <div class="dest-header mb-32 md:mb-64 max-w-4xl relative z-10">
      <br /><br /><br /><br />
      <DisplayTitle as="h2" class="text-midnight leading-[0.9]">
        El mapa<br />no es el territorio.
      </DisplayTitle>
      <p class="font-sans text-lg md:text-xl text-cloud-dark mt-8 max-w-xl leading-relaxed">
        No coleccionamos pines en un mapa. Buscamos lugares que nos obliguen a cambiar nuestra perspectiva del mundo. <br /><br />
      </p>
    </div>

    <div class="destinations-editorial-grid flex flex-col gap-32 md:gap-64 relative z-10">
      {featuredDestinations.map((dest, index) => {
        const isEven = index % 2 === 0;
        return (
          <div class={`dest-item grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-0 items-center`}>
            <!-- Imagen Gigante (Parallax Mask) -->
            <div class={`dest-image-col col-span-1 md:col-span-8 ${isEven ? 'md:col-start-1' : 'md:col-start-5'} relative z-10`}>
              <div class="overflow-hidden bg-midnight aspect-[4/3] md:aspect-[16/10]">
                <img 
                  src={dest.image} 
                  alt={dest.alt}
                  loading="lazy"
                  class="dest-image w-full h-full object-cover origin-center scale-[1.15] transform-gpu"
                />
              </div>
            </div>
            
            <!-- Tipografía Flotante Asimétrica -->
            <div class={`dest-text-col col-span-1 md:col-span-6 ${isEven ? 'md:col-start-7 md:-ml-24' : 'md:col-start-1 md:-mr-24'} relative z-20 flex flex-col justify-center ${isEven ? 'md:items-start' : 'md:items-end text-left md:text-right'}`}>
              <div class="py-4 sm:py-8 md:py-12 w-full max-w-lg">
                <h3 class="font-serif text-4xl sm:text-6xl md:text-8xl lg:text-[9rem] text-midnight mb-4 sm:mb-6 italic leading-none drop-shadow-2xl md:drop-shadow-none break-words">
                  {dest.country}
                </h3>
                <p class="font-sans text-base sm:text-lg md:text-xl text-cloud-dark leading-relaxed mb-6 sm:mb-8 bg-ivory/60 md:bg-transparent backdrop-blur-md md:backdrop-blur-none p-3 sm:p-4 md:p-0 rounded-lg md:rounded-none">
                  "{dest.description}"
                </p>
                <div class={`flex flex-col gap-2 ${isEven ? 'items-start' : 'items-start md:items-end'}`}>
                  <span class="font-sans text-xs uppercase tracking-widest text-cloud-light">{dest.season}</span>
                  <span class="font-sans text-xs uppercase tracking-widest text-sunset">{dest.duration}</span>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </Container>
  <br /><br /><br /><br /><br />
</SectionContainer>

<script>
  import { initDestinationsAnimation } from '@/animations/destinations';

  document.addEventListener('astro:page-load', () => {
    initDestinationsAnimation();
  });
</script>
