---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';
import EditorialImage from '@components/blocks/EditorialImage.astro';
import { destinations } from '@/content/es/destinations';

// Tomamos solo 4 destinos para mantener el impacto editorial alto y no saturar
const featuredDestinations = destinations.slice(0, 4);
---

<SectionContainer id="destinations" padding="xl" class="bg-ivory pt-32 pb-48">
  <Container class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="mb-32 md:mb-48 max-w-4xl">
      <p class="font-sans text-xs uppercase tracking-[0.2em] text-sunset mb-6">Escena 7</p>
      <DisplayTitle as="h2" class="text-midnight leading-[0.9]">
        El mapa<br />no es el territorio.
      </DisplayTitle>
      <p class="font-sans text-lg text-cloud-dark mt-8 max-w-xl leading-relaxed">
        No coleccionamos pines en un mapa. Buscamos lugares que nos obliguen a cambiar nuestra perspectiva del mundo.
      </p>
    </div>

    <div class="destinations-editorial-grid flex flex-col gap-32 md:gap-48 relative z-10">
      {featuredDestinations.map((dest, index) => {
        const isEven = index % 2 === 0;
        return (
          <div class={`dest-item grid grid-cols-1 md:grid-cols-12 gap-8 items-center ${isEven ? '' : 'md:dir-rtl'}`}>
            <!-- Imagen Gigante -->
            <div class={`col-span-1 md:col-span-7 ${isEven ? 'md:col-start-1' : 'md:col-start-6'} relative group`}>
              <div class="overflow-hidden bg-midnight">
                <img 
                  src={dest.image} 
                  alt={dest.alt}
                  class="w-full h-auto aspect-[4/3] object-cover opacity-90 transition-transform duration-1000 group-hover:scale-105 group-hover:opacity-100"
                />
              </div>
            </div>
            
            <!-- Tipografía Flotante -->
            <div class={`col-span-1 md:col-span-6 ${isEven ? 'md:col-start-7 md:-ml-24' : 'md:col-start-1 md:-mr-24'} relative z-20 flex flex-col justify-center ${isEven ? 'md:items-start' : 'md:items-end text-right'}`}>
              <div class="bg-ivory/80 backdrop-blur-sm p-8 md:p-12 shadow-2xl shadow-midnight/5 w-full max-w-md">
                <h3 class="font-serif text-5xl md:text-7xl text-midnight mb-6 italic">{dest.country}</h3>
                <p class="font-sans text-lg text-cloud-dark leading-relaxed mb-8">
                  "{dest.description}"
                </p>
                <div class={`flex flex-col gap-2 ${isEven ? 'items-start' : 'items-end'}`}>
                  <span class="font-sans text-xs uppercase tracking-widest text-cloud-light">{dest.season}</span>
                  <span class="font-sans text-xs uppercase tracking-widest text-sunset">{dest.duration}</span>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </Container>
</SectionContainer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    const items = document.querySelectorAll('.dest-item');
    
    items.forEach((item) => {
      gsap.fromTo(item,
        { opacity: 0, y: 100 },
        {
          opacity: 1, 
          y: 0,
          duration: 1.5,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: item,
            start: 'top 75%',
          }
        }
      );
    });
  });
</script>
