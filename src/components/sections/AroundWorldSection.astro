---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import { stories } from '@/content/es/stories';

// For Scene 2, we just want to show the first 3 stories around the globe
const globeStories = stories.slice(0, 3);
---

<SectionContainer id="around-the-world" padding="xl" class="min-h-screen flex items-center justify-center bg-ivory overflow-visible">
  <Container class="relative w-full max-w-6xl mx-auto flex flex-col items-center justify-center pt-20 pb-32">
    
    <!-- Stylized CSS Globe -->
    <div class="relative w-64 h-64 md:w-96 md:h-96 rounded-full globe-container mx-auto z-10 shadow-[0_0_80px_rgba(46,134,222,0.15)] bg-gradient-to-tr from-midnight to-ocean-dark overflow-hidden flex items-center justify-center border border-ocean/20">
      
      <!-- Globe Grid Overlay (SVG) -->
      <svg class="absolute inset-0 w-full h-full opacity-30 animate-spin-slow" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <g stroke="currentColor" stroke-width="0.5" fill="none" class="text-ivory">
          <circle cx="50" cy="50" r="48" />
          <ellipse cx="50" cy="50" rx="24" ry="48" />
          <path d="M 50 2 L 50 98" />
          <path d="M 2 50 L 98 50" />
          <path d="M 12 25 L 88 25" />
          <path d="M 12 75 L 88 75" />
        </g>
      </svg>
      
      <div class="absolute inset-0 rounded-full shadow-[inset_-20px_-20px_40px_rgba(0,0,0,0.5)] pointer-events-none"></div>
    </div>

    <!-- Floating Stories (Positioned absolutely around the globe) -->
    <!-- In a real implementation with GSAP these would orbit or fade in/out on scroll.
         For Phase 2, we position them statically around the globe to establish layout. -->
    <div class="absolute inset-0 z-20 pointer-events-none flex items-center justify-center w-full h-full">
      {globeStories.map((story, index) => {
        // Simple manual positioning for the 3 stories
        const positions = [
          'top-[10%] left-[5%] md:left-[15%]',
          'top-[50%] right-[5%] md:right-[15%] -translate-y-1/2',
          'bottom-[10%] left-[10%] md:left-[25%]'
        ];
        
        return (
          <div class={`absolute ${positions[index]} max-w-[280px] md:max-w-[320px] bg-ivory-warm/95 backdrop-blur-md p-5 rounded-2xl shadow-lg border border-cloud/10 pointer-events-auto story-card-float`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full overflow-hidden shrink-0">
                <img src={story.image} alt={story.alt} class="w-full h-full object-cover" />
              </div>
              <div class="flex flex-col">
                <span class="font-sans text-[10px] font-semibold uppercase tracking-wider text-sunset">
                  {story.location}
                </span>
                <span class="font-sans text-xs text-cloud-dark">
                  {story.author}
                </span>
              </div>
            </div>
            <p class="font-serif text-lg leading-snug italic text-midnight/90">
              "{story.quote}"
            </p>
          </div>
        );
      })}
    </div>

  </Container>
</SectionContainer>

<script>
  import { initAroundWorldAnimation } from '@/animations/around-world';

  document.addEventListener('astro:page-load', () => {
    initAroundWorldAnimation();
  });
</script>
