---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import SectionTitle from '@components/common/SectionTitle.astro';
import Eyebrow from '@components/common/Eyebrow.astro';
import BodyText from '@components/common/BodyText.astro';
import FeatureCard from '@components/cards/FeatureCard.astro';
import EditorialImage from '@components/blocks/EditorialImage.astro';
import { aboutData, philosophyReasons, statistics } from '@/content/es/about';
---

<SectionContainer id="about" padding="none" class="bg-ivory pt-32 pb-32">
  <Container class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
      {/* Sticky Image Column */}
      <div class="col-span-1 lg:col-span-5 relative">
        <div class="lg:sticky lg:top-32 h-fit flex flex-col gap-8 about-sticky-col">
          <div class="overflow-hidden rounded-sm">
            <EditorialImage
              src={aboutData.image}
              alt={aboutData.alt}
              aspectRatio="portrait"
              class="w-full transform-gpu scale-105 about-image"
            />
          </div>

          {/* Statistics - Integrated cleanly below the image with generous breathing room */}
          <div
            class="bg-midnight text-ivory p-5 sm:p-6 md:p-7 xl:p-8 rounded-2xl shadow-xl border border-white/10 grid grid-cols-3 gap-3 sm:gap-5 lg:gap-4 xl:gap-6 w-full text-center sm:text-left about-stats"
          >
            {
              statistics.map((stat) => (
                <div class="flex flex-col min-w-0 justify-start">
                  <div class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-3xl xl:text-4xl mb-1 text-ivory flex flex-wrap justify-center sm:justify-start items-baseline gap-0.5 font-normal">
                    <span class="stat-counter" data-target={stat.value.replace(/[^0-9]/g, '')}>
                      0
                    </span>
                    <span class="text-sunset">{stat.value.replace(/[0-9]/g, '')}</span>
                  </div>
                  <div class="font-sans text-[9px] sm:text-[10px] lg:text-[11px] xl:text-xs uppercase tracking-wider text-sunset font-medium mb-1.5 leading-snug break-words">
                    {stat.label}
                  </div>
                  {stat.description && (
                    <div class="font-sans text-[11px] lg:text-[11px] xl:text-xs text-cloud-light/65 hidden sm:block leading-relaxed">
                      {stat.description}
                    </div>
                  )}
                </div>
              ))
            }
          </div>
        </div>
      </div>

      {/* Content Column */}
      <div class="col-span-1 lg:col-span-7 flex flex-col justify-center about-content-col lg:pt-16">
        <Eyebrow text={aboutData.philosophy} class="mb-6" />
        <SectionTitle as="h2" class="text-midnight mb-10 text-balance leading-tight">
          {aboutData.title}
        </SectionTitle>

        <div class="space-y-6 mb-20 max-w-2xl text-lg text-cloud-dark leading-relaxed">
          {aboutData.paragraphs.map((p) => <BodyText>{p}</BodyText>)}
        </div>

        <br /><br />

        {/* Reasons Grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
          {
            philosophyReasons.map((reason) => (
              <div class="about-reason-item">
                <FeatureCard title={reason.title} description={reason.description} />
              </div>
            ))
          }
        </div>
        <br /><br />
      </div>
    </div>
  </Container>
</SectionContainer>

<script>
  import { initAboutAnimation } from '@/animations/about';

  document.addEventListener('astro:page-load', () => {
    initAboutAnimation();
  });
</script>
