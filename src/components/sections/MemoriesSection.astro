---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';
import Quote from '@components/common/Quote.astro';
import EditorialImage from '@components/blocks/EditorialImage.astro';

import mem1Img from '@/assets/images/memory-nostalgic-sunset.webp';
import mem2Img from '@/assets/images/memory-paris-street.webp';
import mem3Img from '@/assets/images/memory-forest-mist.webp';


const memoryImages = [
  mem1Img.src, // Nostalgic sunset
  mem2Img.src, // Paris quiet street
  mem3Img.src, // Forest mist
];
---

<SectionContainer id="memories" padding="xl" class="bg-midnight" dark>
  <Container class="max-w-4xl mx-auto text-center px-4">
    <!-- Huge image -->
    <div class="mb-32 md:mb-48 w-full max-w-5xl mx-auto">
      <EditorialImage 
        src={memoryImages[0]}
        alt="Atardecer nostálgico sobre el agua"
        aspectRatio="landscape"
        class="rounded-none opacity-90 w-full"
        dark
      />
    </div>

    <!-- Phrase -->
    <div class="mb-32 md:mb-48 max-w-3xl mx-auto">
      <Quote author="Grecia, 2022" class="text-left md:text-center md:border-l-0 text-3xl md:text-5xl" dark>
        Volvería únicamente para escuchar otra vez aquel atardecer.
      </Quote>
    </div>

    <!-- Smaller layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-8 mb-32 md:mb-48 max-w-6xl mx-auto">
      <div class="col-span-1 md:col-span-5 md:mt-24">
        <EditorialImage 
          src={memoryImages[1]}
          alt="Callejón tranquilo al amanecer"
          aspectRatio="portrait"
          class="rounded-none opacity-90 w-full"
          dark
        />
      </div>
      <div class="col-span-1 md:col-span-6 md:col-start-7 flex items-center justify-center">
        <Quote author="París, 2024" class="text-2xl md:text-4xl leading-relaxed" dark>
          No recuerdo el nombre del restaurante.<br/>Pero sí recuerdo las risas.
        </Quote>
      </div>
    </div>

    <!-- Final large image -->
    <div class="mb-32 md:mb-48 max-w-4xl mx-auto">
      <EditorialImage 
        src={memoryImages[2]}
        alt="Bosque envuelto en niebla matutina"
        aspectRatio="video"
        class="rounded-none opacity-80 w-full"
        dark
      />
    </div>

    <!-- Final phrase -->
    <div>
      <DisplayTitle as="h2" class="text-ivory">
        El viaje terminó.<br />La historia no.
      </DisplayTitle>
    </div>
  </Container>
</SectionContainer>

<script>
  import { initMemoriesAnimation } from '@/animations/memories';

  document.addEventListener('astro:page-load', () => {
    initMemoriesAnimation();
  });
</script>
