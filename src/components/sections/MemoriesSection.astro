---
import SectionContainer from '@components/layout/SectionContainer.astro';
import DisplayTitle from '@components/common/DisplayTitle.astro';
import EditorialImage from '@components/blocks/EditorialImage.astro';

import mem1Img from '@/assets/images/memory-nostalgic-sunset.webp';
import mem2Img from '@/assets/images/memory-paris-street.webp';
import mem3Img from '@/assets/images/memory-forest-mist.webp';

const memories = [
  {
    src: mem1Img.src,
    alt: 'Atardecer nostálgico sobre el agua',
    aspect: 'landscape',
    quote: "Volvería únicamente para escuchar otra vez aquel atardecer.",
    author: "Grecia, 2022",
    align: 'left-[4%] sm:left-[5%] md:left-[10%] top-[12%]',
    width: 'w-[88vw] max-w-[340px] sm:w-[60vw] md:w-[45vw]',
    speed: 1.2
  },
  {
    src: mem2Img.src,
    alt: 'Callejón tranquilo al amanecer',
    aspect: 'portrait',
    quote: "No recuerdo el nombre del restaurante. Pero sí recuerdo las risas.",
    author: "París, 2024",
    align: 'right-[4%] sm:right-[5%] md:right-[15%] top-[45%]',
    width: 'w-[78vw] max-w-[300px] sm:w-[50vw] md:w-[30vw]',
    speed: 1.0
  },
  {
    src: mem3Img.src,
    alt: 'Bosque envuelto en niebla matutina',
    aspect: 'video',
    quote: "El silencio de aquella montaña lo decía todo.",
    author: "Japón, 2023",
    align: 'left-[5%] sm:left-[10%] md:left-[20%] top-[78%]',
    width: 'w-[88vw] max-w-[340px] sm:w-[65vw] md:w-[50vw]',
    speed: 1.1
  }
];
---

<SectionContainer id="memories" padding="none" class="bg-ivory relative z-20 overflow-hidden">
  
  <!-- 1. Transition Screen (Cierre de Ojos) -->
  <div id="memory-transition-screen" class="h-screen w-full flex items-center justify-center bg-ivory px-4">
    <div class="text-center max-w-4xl mx-auto opacity-0" id="memory-intro-text">
      <span class="font-sans text-xs sm:text-sm md:text-base tracking-[0.2em] uppercase block mb-3 sm:mb-4 text-midnight/60">La Memoria</span>
      <DisplayTitle as="h2" class="text-2xl sm:text-4xl md:text-5xl lg:text-6xl leading-tight text-midnight break-words">
        Pero al final del viaje...<br />lo que queda son fragmentos.
      </DisplayTitle>
    </div>
  </div>

  <!-- 2. The Memory Void -->
  <div id="memory-void" class="relative w-full h-[250vh] sm:h-[300vh] bg-midnight z-10 pointer-events-none overflow-hidden">
    {memories.map((memory) => (
      <div class={`memory-fragment absolute ${memory.align} ${memory.width} flex flex-col gap-4 sm:gap-6 md:gap-8 pointer-events-auto`} data-speed={memory.speed}>
        
        <!-- Image Container -->
        <div class="memory-image-wrapper overflow-hidden relative shadow-2xl shadow-midnight/50 rounded-sm">
          <EditorialImage 
            src={memory.src}
            alt={memory.alt}
            aspectRatio={memory.aspect as any}
            class="memory-image rounded-none w-full scale-125 transform-gpu"
          />
        </div>

        <!-- Magnetic Quote -->
        <div class="memory-quote-wrapper flex flex-col px-1 sm:px-4 md:px-0">
          <p class="font-serif text-lg sm:text-2xl md:text-4xl lg:text-5xl text-ivory italic leading-snug break-words">
            "{memory.quote}"
          </p>
          <span class="font-sans text-[10px] sm:text-xs md:text-sm tracking-widest uppercase text-ivory/60 mt-2 sm:mt-4 block">
            {memory.author}
          </span>
        </div>
        
      </div>
    ))}
  </div>

  <!-- Final Anchor to next section -->
  <div class="h-screen w-full bg-midnight flex items-center justify-center relative z-20">
    <DisplayTitle as="h2" class="text-ivory text-center px-4" id="memory-outro-text">
      El viaje terminó.<br />La historia no.
    </DisplayTitle>
  </div>

</SectionContainer>

<script>
  import { initMemoriesAnimation } from '@/animations/memories';

  document.addEventListener('astro:page-load', () => {
    initMemoriesAnimation();
  });
</script>
