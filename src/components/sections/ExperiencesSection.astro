---
import SectionContainer from '@components/layout/SectionContainer.astro';
import Container from '@components/common/Container.astro';
import { experiences } from '@/content/es/experiences';
---

<SectionContainer id="experiences" padding="none" class="bg-midnight relative overflow-hidden min-h-screen flex items-center py-32 z-10">
  
  <!-- Contenedor de imágenes de fondo (Cinematic Crossfade) -->
  <div class="exp-images-container absolute inset-0 z-0 pointer-events-none">
    {experiences.map((exp, index) => (
      <div class="exp-image-wrapper absolute inset-0 w-full h-full opacity-0" data-exp-img={index}>
        <img 
          src={exp.image}
          alt={exp.title}
          loading="lazy"
          class="w-full h-full object-cover transform-gpu"
        />
      </div>
    ))}
    <!-- Overlay de contraste: Un gradiente oscuro fuerte del lado izquierdo para asegurar legibilidad absoluta -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#070F18]/95 via-[#070F18]/75 to-transparent w-full md:w-3/4 lg:w-2/3 pointer-events-none"></div>
  </div>

  <Container class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8 flex flex-col justify-center min-h-[70vh]">
    <div class="max-w-2xl mb-16 md:mb-24">
      <h2 class="font-sans text-2xl md:text-4xl !text-white leading-relaxed font-light drop-shadow-xl">
        El mundo no es una lista de lugares para ver. Es una colección infinita de formas de sentir.
      </h2>
      <br>
    </div>

    <!-- Menú tipográfico gigante interactivo -->
    <div class="flex flex-col w-full max-w-5xl">
      {experiences.map((exp, index) => (
        <div 
          class="exp-item group relative py-4 md:py-8 border-b border-white/10 cursor-pointer flex flex-col md:flex-row md:items-center justify-between"
          data-exp-index={index}
        >
          <h3 class="exp-title font-serif text-5xl md:text-7xl lg:text-[7rem] leading-none !text-white/50 transition-colors duration-500 ease-out pr-8">
            {exp.title}
          </h3>
          <p class="exp-desc font-sans text-base md:text-lg !text-white max-w-[320px] md:text-right mt-4 md:mt-0 opacity-0 transform translate-x-4 transition-all duration-500 ease-out">
            {exp.description}
          </p>
        </div>
      ))}
    </div>
  </Container>
</SectionContainer>

<script>
  import { initExperiencesAnimation } from '@/animations/experiences';

  document.addEventListener('astro:page-load', () => {
    initExperiencesAnimation();
  });
</script>
