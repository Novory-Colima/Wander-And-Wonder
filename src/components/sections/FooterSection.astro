---
import Container from '@components/common/Container.astro';
import { NAV_LINKS, SITE_CONFIG } from '@/config/site';

const currentYear = new Date().getFullYear();

const footerColumns = [
  {
    title: 'Explorar',
    links: [
      { label: 'Experiencias', href: '#experiences' },
      { label: 'Destinos', href: '#destinations' },
      { label: 'Historias', href: '#stories' },
    ],
  },
  {
    title: 'Nosotros',
    links: [
      { label: 'Nuestra filosofía', href: '#about' },
      { label: 'Contacto', href: '#contact' },
    ],
  },
  {
    title: 'Contacto',
    links: [
      { label: 'hello@wanderandwonder.com', href: 'mailto:hello@wanderandwonder.com' },
    ],
  },
];

const socialLinks = [
  { label: 'Instagram', href: '#', icon: 'instagram' },
  { label: 'Twitter', href: '#', icon: 'twitter' },
  { label: 'YouTube', href: '#', icon: 'youtube' },
];
---

<footer
  class="relative bg-midnight pt-20 pb-8 md:pt-28 md:pb-10"
  role="contentinfo"
>
  <Container>
    <!-- Top section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 md:gap-8 pb-12 md:pb-16 border-b border-ivory/8">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="#hero" class="inline-block mb-5" aria-label="Wander & Wonder — Inicio">
          <span class="font-serif text-2xl font-semibold text-ivory tracking-tight">
            Wander<span class="text-sunset">&</span>Wonder
          </span>
        </a>
        <p class="font-sans text-sm text-ivory/50 leading-relaxed max-w-xs">
          Colecciona historias que contarás para siempre.
        </p>

        <!-- Social Links -->
        <div class="flex items-center gap-4 mt-6">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              class="w-9 h-9 flex items-center justify-center rounded-full border border-ivory/10 text-ivory/40 hover:text-ivory hover:border-ivory/30 transition-all duration-300"
              aria-label={social.label}
            >
              <span class="text-xs font-sans font-medium uppercase">
                {social.icon.charAt(0).toUpperCase()}
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation Columns -->
      {footerColumns.map((column) => (
        <div>
          <h3 class="font-sans text-xs font-semibold uppercase tracking-[0.2em] text-sunset mb-5">
            {column.title}
          </h3>
          <ul class="space-y-3">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-sans text-sm text-ivory/50 hover:text-ivory transition-colors duration-300"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom section -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8">
      <p class="font-sans text-xs text-ivory/30">
        &copy; {currentYear} {SITE_CONFIG.name}. Todos los derechos reservados.
      </p>
      <p class="font-sans text-xs text-ivory/20">
        Un proyecto de portafolio creativo.
      </p>
    </div>
  </Container>
</footer>
