---
import Container from '@components/common/Container.astro';
import { SITE_CONFIG } from '@/config/site';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: 'Instagram', href: '#', icon: 'In' },
  { label: 'Twitter', href: '#', icon: 'Tw' },
  { label: 'YouTube', href: '#', icon: 'Yt' },
];
---

<footer
  class="relative bg-midnight pt-32 pb-8 overflow-hidden flex flex-col justify-between min-h-[90vh] z-0"
  role="contentinfo"
>
  <!-- Background Noise -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

  <Container class="relative z-10 flex flex-col justify-between h-full flex-grow">
    
    <!-- Top section: Call to action & Links -->
    <div class="flex flex-col md:flex-row justify-between items-start gap-16 md:gap-0 mt-12">
      <div class="max-w-md">
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-ivory leading-tight mb-8">
          ¿Listo para <br/><span class="italic text-sunset">perderte</span> un rato?
        </h2>
        <a href="mailto:hello@wanderandwonder.com" class="magnetic-button inline-flex items-center gap-4 group">
          <span class="w-12 h-12 rounded-full border border-ivory/20 flex items-center justify-center group-hover:bg-sunset group-hover:border-sunset transition-all duration-500">
            <svg class="w-4 h-4 text-ivory -rotate-45 group-hover:rotate-0 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </span>
          <span class="font-sans text-sm uppercase tracking-widest text-ivory/70 group-hover:text-ivory transition-colors duration-500">
            hello@wanderandwonder.com
          </span>
        </a>
      </div>

      <div class="flex gap-16 md:gap-24">
        <div>
          <h3 class="font-sans text-xs font-semibold uppercase tracking-[0.2em] text-sunset mb-6">Explorar</h3>
          <ul class="space-y-4">
            <li><a href="#experiences" class="font-sans text-lg text-ivory/50 hover:text-ivory hover:italic transition-all duration-300">Experiencias</a></li>
            <li><a href="#destinations" class="font-sans text-lg text-ivory/50 hover:text-ivory hover:italic transition-all duration-300">Destinos</a></li>
            <li><a href="#stories" class="font-sans text-lg text-ivory/50 hover:text-ivory hover:italic transition-all duration-300">Historias</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-sans text-xs font-semibold uppercase tracking-[0.2em] text-sunset mb-6">Social</h3>
          <ul class="space-y-4">
            {socialLinks.map((social) => (
              <li>
                <a href={social.href} class="font-sans text-lg text-ivory/50 hover:text-ivory hover:italic transition-all duration-300">
                  {social.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Massive Typography Bottom -->
    <div class="mt-32 w-full flex flex-col items-center">
      <h1 class="font-serif uppercase tracking-tighter text-center text-ivory w-full leading-[0.75] text-[15vw] opacity-90 select-none">
        WANDER<span class="text-sunset">&</span>WONDER
      </h1>
      
      <div class="w-full flex flex-col md:flex-row items-center justify-between gap-4 pt-12 border-t border-ivory/10 mt-8">
        <p class="font-sans text-[10px] md:text-xs text-ivory/30 tracking-widest uppercase">
          &copy; {currentYear} {SITE_CONFIG.name}. Todos los derechos reservados.
        </p>
        <p class="font-sans text-[10px] md:text-xs text-ivory/30 tracking-widest uppercase">
          Diseñado con brutal honestidad.
        </p>
      </div>
    </div>

  </Container>
</footer>
