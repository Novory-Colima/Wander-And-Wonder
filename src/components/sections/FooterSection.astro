---
import Container from '@components/common/Container.astro';
import { SITE_CONFIG } from '@/config/site';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: 'Instagram', href: '#', icon: 'In' },
  { label: 'Twitter', href: '#', icon: 'Tw' },
  { label: 'YouTube', href: '#', icon: 'Yt' },
];
---

<footer
  class="relative bg-midnight pt-32 md:pt-48 pb-12 overflow-hidden flex flex-col justify-end min-h-[90vh] z-0"
  role="contentinfo"
>
  <Container class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8">
    
    <!-- Diseño Editorial Asimétrico para Enlaces y CTA -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-8 mb-32 md:mb-48">
      <!-- Columna Izquierda (CTA) -->
      <div class="md:col-span-6 md:col-start-1">
        <span class="font-sans text-xs uppercase tracking-[0.2em] text-sunset mb-8 block">El Final del Viaje</span>
        <h2 class="font-serif text-5xl md:text-7xl lg:text-[6rem] text-ivory leading-[0.9] mb-12 md:mb-16 italic">
          Perderse <br/>es el mejor <br/>destino.
        </h2>
        <a href="mailto:hello@wanderandwonder.com" class="magnetic-button inline-flex items-center gap-6 group cursor-pointer">
          <span class="font-sans text-sm md:text-base uppercase tracking-widest text-ivory/60 group-hover:text-ivory transition-colors duration-500">
            Comienza tu historia
          </span>
          <span class="w-12 h-12 md:w-16 md:h-16 rounded-full border border-ivory/20 flex items-center justify-center group-hover:bg-sunset group-hover:border-sunset transition-all duration-500">
            <svg class="w-4 h-4 md:w-5 md:h-5 text-ivory -rotate-45 group-hover:rotate-0 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </span>
        </a>
      </div>

      <!-- Columna Derecha (Enlaces) -->
      <div class="md:col-span-4 md:col-start-9 flex flex-col justify-end gap-16 mt-16 md:mt-0">
        <div>
          <h3 class="font-sans text-xs uppercase tracking-[0.2em] text-sunset mb-8">Navegación</h3>
          <ul class="space-y-4">
            <li><a href="#experiences" class="font-sans text-lg text-ivory/40 hover:text-ivory hover:italic transition-all duration-300 block">Experiencias</a></li>
            <li><a href="#destinations" class="font-sans text-lg text-ivory/40 hover:text-ivory hover:italic transition-all duration-300 block">Destinos</a></li>
            <li><a href="#stories" class="font-sans text-lg text-ivory/40 hover:text-ivory hover:italic transition-all duration-300 block">Historias</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-sans text-xs uppercase tracking-[0.2em] text-sunset mb-8">Social</h3>
          <ul class="space-y-4">
            {socialLinks.map((social) => (
              <li>
                <a href={social.href} class="font-sans text-lg text-ivory/40 hover:text-ivory hover:italic transition-all duration-300 block">
                  {social.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Massive Typography Bottom -->
    <div class="w-full flex flex-col">
      <h1 class="font-serif uppercase tracking-tighter text-ivory w-full leading-[0.75] text-[16vw] opacity-90 select-none -ml-2 md:-ml-4">
        WANDER<span class="text-sunset/80">&</span>WONDER
      </h1>
      
      <div class="w-full flex flex-col md:flex-row items-center justify-between gap-4 pt-12 border-t border-ivory/10 mt-12">
        <p class="font-sans text-[10px] md:text-xs text-ivory/30 tracking-widest uppercase">
          &copy; {currentYear} {SITE_CONFIG.name}. Todos los derechos reservados.
        </p>
        <p class="font-sans text-[10px] md:text-xs text-ivory/30 tracking-widest uppercase">
          Diseñado para el mundo.
        </p>
      </div>
    </div>
  </Container>
</footer>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    if (window.matchMedia('(hover: none)').matches) return;
    
    const magnets = document.querySelectorAll('.magnetic-button');
    
    magnets.forEach((magnet) => {
      magnet.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const boundingRect = (magnet as HTMLElement).getBoundingClientRect();
        const relX = mouseEvent.clientX - boundingRect.left;
        const relY = mouseEvent.clientY - boundingRect.top;
        
        gsap.to(magnet, {
          x: (relX - boundingRect.width / 2) * 0.2,
          y: (relY - boundingRect.height / 2) * 0.2,
          ease: 'power2.out',
          duration: 0.3
        });
      });
      
      magnet.addEventListener('mouseleave', () => {
        gsap.to(magnet, {
          x: 0,
          y: 0,
          ease: 'elastic.out(1, 0.3)',
          duration: 1
        });
      });
    });
  });
</script>
