---
interface Props {
  as?: 'h1' | 'h2';
  class?: string;
}

const { as: Tag = 'h1', class: className = '' } = Astro.props;
---

<Tag
  class:list={[
    'font-serif font-medium leading-tight tracking-tight text-balance',
    'text-5xl md:text-6xl lg:text-7xl xl:text-8xl',
    className,
  ]}
>
  <slot />
</Tag>
